# Supabase — copie para .env.local e preencha com os valores do seu projeto
# (Project Settings → API no painel do Supabase).

# URL do projeto (ex.: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública (anon) — segura para o navegador
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave service-role — SECRETA, somente no servidor. Nunca expor no client.
SUPABASE_SERVICE_ROLE_KEY=
